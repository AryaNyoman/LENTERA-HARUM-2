# Salin file ini menjadi `.env` lalu isi nilainya. JANGAN commit .env.

# Dev lokal (SQLite). Di Railway diganti connection string Postgres.
DATABASE_URL="file:./dev.db"

# Kunci enkripsi PII anak di database website ini (AES-256-GCM, 32 byte hex).
# Buat dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KUNCI_SERVER=""

# ── Sinkron SIMPUS (boleh kosong dulu; sinkron menolak jalan sampai diisi) ──
# Connection string Neon milik SIMPUS petugas (pakai yang pooled).
SIMPUS_DATABASE_URL=""
# Amplop layanan: DEK brankas SIMPUS (hex 64 karakter). Cara mendapatkannya:
#   di repo Simpus-Imun jalankan: npx tsx scripts/export-dek-layanan.ts
#   (diminta password admin SIMPUS; hasilnya tempel ke sini / env Railway.)
SIMPUS_DEK=""
# Rahasia pemicu sinkron terjadwal: GET /api/sinkron?rahasia=<ini> (Railway cron mingguan).
CRON_SECRET=""
